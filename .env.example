# Copy to .env and fill in. Never commit .env.

# --- Database (§2.1) -------------------------------------------------------
# Point this at any PostgreSQL 15+ instance. The schema uses gen_random_uuid(),
# which is core from PG13 onward — no pgcrypto extension needed.
#
# TWO ROLES, ON PURPOSE. Run scripts/provision-roles.sql once per database to
# create them (it verifies its own work and tells you if anything is off).
#
#   examhub_app       serves requests. Owns nothing, cannot run DDL, cannot read
#                     pg_authid, cannot SET ROLE back to anything privileged.
#   examhub_migrator  owns the schema, runs migrations, never serves a request.
#
# Connecting the API as a superuser means the ONLY thing between a bug and every
# tenant's data is application code. That is one layer, and it has been wrong
# before (see question-selection.ts's history). A superuser also silently
# ignores row-level security, so any future RLS work is decorative until this is
# in place.
#
# Passwords with @ or / must be URL-encoded (@ → %40) or the connection string
# parser reads them as the host.
DATABASE_URL="postgresql://examhub_app:CHANGEME@localhost:5432/bookends?schema=public"

# Migrations only. `npm run db:migrate` needs DDL rights the app role must not
# have — that separation is the point, not an inconvenience.
MIGRATE_DATABASE_URL="postgresql://examhub_migrator:CHANGEME@localhost:5432/bookends?schema=public"

# --- API -------------------------------------------------------------------
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Comma-separated origins allowed to call the API with credentials.
# Leave empty when the API is served same-origin behind a reverse proxy.
CORS_ORIGINS=""

# --- Auth (§7.2) -----------------------------------------------------------
# Access-token signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# The API refuses to boot in production if this is unset or under 32 chars.
JWT_SECRET=""
JWT_ACCESS_TTL_SECONDS=900          # 15 minutes (§7.2)
REFRESH_TTL_SECONDS=604800          # 7 days (§7.2)

# --- Sessions (§7.5) -------------------------------------------------------
# postgres | memory. `memory` is for tests only — the API refuses to boot with
# it when NODE_ENV=production, since it silently breaks multi-instance deploys.
SESSION_STORE=postgres
SESSION_IDLE_TTL_STAFF_SECONDS=1800   # 30 minutes (§7.5)
SESSION_IDLE_TTL_ADMIN_SECONDS=7200   # 2 hours (§7.5)

# Redis is NOT used for sessions in Module 1. It becomes required at Module 6:
# §2.1 specifies BullMQ for exam scheduling and notifications, which needs it.
# REDIS_URL="redis://localhost:6379"

# --- Seed bootstrap (§3.3) -------------------------------------------------
# The seed creates a super admin only when both are set. Leave blank in CI.
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=
