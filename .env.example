# Copy to .env and fill in. Never commit .env.

# --- Database (§2.1) -------------------------------------------------------
# Supabase (or any PostgreSQL 15+). The schema uses gen_random_uuid(), which is
# core from PG13 onward — no pgcrypto extension needed.
#
# Both are required and they are different endpoints. Copy them from the
# Supabase dashboard: Project Settings -> Database -> Connection string.
#
#   DATABASE_URL  pooled,  port 6543  — the API's own traffic
#   DIRECT_URL    direct,  port 5432  — prisma migrate / introspect / studio
#
# `pgbouncer=true` is not optional on the pooled URL: it stops Prisma emitting
# prepared statements, which transaction-mode pooling cannot support.
# Do NOT add `connection_limit=1` — that is for serverless. This API is a
# long-lived process and wants Prisma's default pool.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- API -------------------------------------------------------------------
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Comma-separated origins allowed to call the API with credentials.
# Leave empty when the API is served same-origin behind a reverse proxy.
CORS_ORIGINS=""

# --- Auth (§7.2) -----------------------------------------------------------
# Access-token signing secret. REQUIRED — generate your own with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#
# The API refuses to boot without it, in every environment except tests. That is
# deliberate: it used to fall back to a constant committed to this repository
# whenever NODE_ENV was not exactly "production", and forgetting NODE_ENV in a
# container is a common enough mistake that the fallback was a live risk.
JWT_SECRET=""
JWT_ACCESS_TTL_SECONDS=900          # 15 minutes (§7.2)
REFRESH_TTL_SECONDS=604800          # 7 days (§7.2)

# --- Sessions (§7.5) -------------------------------------------------------
# postgres | memory. `memory` is for tests only — the API refuses to boot with
# it when NODE_ENV=production, since it silently breaks multi-instance deploys.
SESSION_STORE=postgres
SESSION_IDLE_TTL_STAFF_SECONDS=1800   # 30 minutes (§7.5)
SESSION_IDLE_TTL_ADMIN_SECONDS=7200   # 2 hours (§7.5)

# Redis is NOT used for sessions in Module 1. It becomes required at Module 6:
# §2.1 specifies BullMQ for exam scheduling and notifications, which needs it.
# REDIS_URL="redis://localhost:6379"

# --- Seed bootstrap (§3.3) -------------------------------------------------
# The seed creates a super admin only when both are set. Leave blank in CI.
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=
