{
  "name": "bookends-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Bookends Hospitality — Staff Performance & Examination Portal",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty",
    "typecheck:tests": "tsc --noEmit -p apps/api/tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "npm run generate -w @bookends/db",
    "db:deploy": "npm run migrate:deploy -w @bookends/db",
    "db:migrate": "npm run migrate:dev -w @bookends/db",
    "db:seed": "npm run seed -w @bookends/db",
    "db:studio": "npm run studio -w @bookends/db",
    "dev": "concurrently -n api,web -c blue,magenta --kill-others-on-fail \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev -w @bookends/api",
    "dev:web": "npm run dev -w @bookends/web",
    "db:demo": "npm run demo -w @bookends/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
