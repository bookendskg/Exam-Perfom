{
  "name": "bookends-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Bookends Hospitality — Staff Performance & Examination Portal",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "npm run generate -w @bookends/db",
    "db:migrate": "npm run migrate:dev -w @bookends/db",
    "db:seed": "npm run seed -w @bookends/db",
    "db:studio": "npm run studio -w @bookends/db",
    "dev": "npm run dev -w @bookends/api",
    "dev:db": "node scripts/dev-db.mjs",
    "dev:admin": "npm run dev -w @bookends/admin",
    "build:admin": "npm run build -w @bookends/admin"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "embedded-postgres": "^17.5.0-beta.15"
  },
  "allowScripts": {
    "@embedded-postgres/windows-x64@17.5.0-beta.15": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true
  }
}
