{
  "name": "@bookends/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prisma schema, migrations and seed data for the Bookends staff performance portal",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "build": "tsc -b",
    "generate": "prisma generate",
    "validate": "prisma validate",
    "format": "prisma format",
    "migrate:dev": "node scripts/with-migrator.mjs migrate dev",
    "migrate:deploy": "node scripts/with-migrator.mjs migrate deploy",
    "studio": "prisma studio",
    "seed": "tsx --env-file-if-exists=../../.env prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@bookends/core": "*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "tsx": "^4.19.2"
  }
}
