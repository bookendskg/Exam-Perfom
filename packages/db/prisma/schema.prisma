// Bookends Hospitality — Staff Performance & Examination Portal
// Data model per Master Development Prompt v1.0 §4.
//
// Trilingual convention (§6.2): every staff-facing text field is stored as a
// triple — `<field>En` is NOT NULL, `<field>Hi` and `<field>Gu` are nullable.
// Resolution falls back gu -> hi -> en at the API layer, never in the database.

generator client {
  provider = "prisma-client-js"
}

// `url` is the pooled connection (Supabase's pgbouncer, port 6543); `directUrl`
// is the direct one (port 5432). Both are required, and they are not
// interchangeable: Prisma Migrate's schema engine holds a single session and
// issues DDL in transactions, which transaction-mode pooling cannot carry — so
// migrate and introspect go direct while the application traffic goes pooled.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

